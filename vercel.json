{
  "rewrites": [
    { "source": "/admin", "destination": "/admin/" },
    { "source": "/admin/", "destination": "/admin.html" },
    { "source": "/login", "destination": "/login/" },
    { "source": "/login/", "destination": "/login.html" },
    { "source": "/((?!admin|login|favicon.ico).*)", "destination": "/index.html" }
  ]
}
